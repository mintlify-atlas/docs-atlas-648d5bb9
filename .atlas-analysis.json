  "keyFeatures": [
    "Timer control (start, split, reset, game time management)",
    "Process attachment and memory reading for game data extraction",
    "Typed memory watchers for detecting value changes across update cycles",
    "User-configurable boolean settings exposed to LiveSplit One's UI",
    "Runtime introspection (OS, architecture, tick rate control)",
    "WebAssembly output via AssemblyScript compilation"
  ],
